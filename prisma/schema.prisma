generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  CUSTOMER
  EMPLOYEE
  MANAGER
  SALON_OWNER
  ADMIN
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  REJECTED
  NO_SHOW
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

// ─── User ────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String?
  firstName     String
  lastName      String
  phone         String?
  avatarUrl     String?
  role          Role      @default(CUSTOMER)
  isActive      Boolean   @default(true)
  isVerified    Boolean   @default(false)
  googleId      String?   @unique
  refreshToken  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  // Relations
  ownedSalons       Salon[]        @relation("SalonOwner")
  staffProfile      StaffMember?
  appointments      Appointment[]  @relation("CustomerAppointments")
  reviews           Review[]
  favoriteSalons    FavoriteSalon[]

  @@map("users")
}

// ─── Salon ───────────────────────────────────────────────────────────────────

model Salon {
  id          String    @id @default(uuid())
  ownerId     String
  name        String
  slug        String    @unique
  description String?
  type        String    // "hair", "nails", "spa", "barber", etc.
  phone       String?
  email       String?
  website     String?
  instagram   String?
  facebook    String?
  address     String?
  city        String?
  country     String    @default("BA")
  latitude    Float?
  longitude   Float?
  logoUrl     String?
  coverUrl    String?
  isActive    Boolean   @default(true)
  isVerified  Boolean   @default(false)
  isFeatured  Boolean   @default(false)
  rating      Float     @default(0)
  reviewCount Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  // Relations
  owner           User              @relation("SalonOwner", fields: [ownerId], references: [id])
  staff           StaffMember[]
  services        Service[]
  serviceCategories ServiceCategory[]
  workingHours    WorkingHours[]
  appointments    Appointment[]
  reviews         Review[]
  images          SalonImage[]
  favoritedBy     FavoriteSalon[]

  @@map("salons")
}

// ─── Service Category ─────────────────────────────────────────────────────────

model ServiceCategory {
  id        String    @id @default(uuid())
  salonId   String
  name      String
  color     String    @default("#C9A84C")
  sortOrder Int       @default(0)
  createdAt DateTime  @default(now())

  salon     Salon     @relation(fields: [salonId], references: [id], onDelete: Cascade)
  services  Service[]

  @@map("service_categories")
}

// ─── Service ─────────────────────────────────────────────────────────────────

model Service {
  id          String    @id @default(uuid())
  salonId     String
  categoryId  String?
  name        String
  description String?
  duration    Int       // minutes
  price       Float
  color       String    @default("#C9A84C")
  imageUrl    String?
  isActive    Boolean   @default(true)
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  salon        Salon            @relation(fields: [salonId], references: [id], onDelete: Cascade)
  category     ServiceCategory? @relation(fields: [categoryId], references: [id])
  staffMembers StaffService[]
  appointments Appointment[]

  @@map("services")
}

// ─── Staff ───────────────────────────────────────────────────────────────────

model StaffMember {
  id          String    @id @default(uuid())
  userId      String    @unique
  salonId     String
  bio         String?
  title       String?   // "Senior Stylist", "Color Specialist", etc.
  isActive    Boolean   @default(true)
  rating      Float     @default(0)
  reviewCount Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user         User             @relation(fields: [userId], references: [id])
  salon        Salon            @relation(fields: [salonId], references: [id], onDelete: Cascade)
  services     StaffService[]
  schedules    StaffSchedule[]
  appointments Appointment[]

  @@map("staff_members")
}

model StaffService {
  staffId   String
  serviceId String

  staff   StaffMember @relation(fields: [staffId], references: [id], onDelete: Cascade)
  service Service     @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([staffId, serviceId])
  @@map("staff_services")
}

// ─── Schedules ───────────────────────────────────────────────────────────────

model WorkingHours {
  id         String    @id @default(uuid())
  salonId    String
  dayOfWeek  DayOfWeek
  openTime   String    // "09:00"
  closeTime  String    // "18:00"
  isClosed   Boolean   @default(false)

  salon Salon @relation(fields: [salonId], references: [id], onDelete: Cascade)

  @@unique([salonId, dayOfWeek])
  @@map("working_hours")
}

model StaffSchedule {
  id         String    @id @default(uuid())
  staffId    String
  dayOfWeek  DayOfWeek
  startTime  String
  endTime    String
  isOff      Boolean   @default(false)

  staff StaffMember @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, dayOfWeek])
  @@map("staff_schedules")
}

// ─── Appointment ─────────────────────────────────────────────────────────────

model Appointment {
  id          String            @id @default(uuid())
  salonId     String
  customerId  String
  staffId     String
  serviceId   String
  date        DateTime          @db.Date
  startTime   String            // "10:30"
  endTime     String            // "11:15"
  status      AppointmentStatus @default(PENDING)
  totalPrice  Float
  note        String?
  cancelReason String?
  reminderSent Boolean          @default(false)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  salon    Salon       @relation(fields: [salonId], references: [id])
  customer User        @relation("CustomerAppointments", fields: [customerId], references: [id])
  staff    StaffMember @relation(fields: [staffId], references: [id])
  service  Service     @relation(fields: [serviceId], references: [id])
  review   Review?

  @@index([salonId, date])
  @@index([staffId, date])
  @@index([customerId])
  @@map("appointments")
}

// ─── Review ───────────────────────────────────────────────────────────────────

model Review {
  id            String    @id @default(uuid())
  salonId       String
  customerId    String
  appointmentId String    @unique
  rating        Int       // 1-5
  comment       String?
  ownerReply    String?
  isVisible     Boolean   @default(true)
  createdAt     DateTime  @default(now())

  salon       Salon       @relation(fields: [salonId], references: [id])
  customer    User        @relation(fields: [customerId], references: [id])
  appointment Appointment @relation(fields: [appointmentId], references: [id])

  @@map("reviews")
}

// ─── Salon Images ─────────────────────────────────────────────────────────────

model SalonImage {
  id        String   @id @default(uuid())
  salonId   String
  url       String
  caption   String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  salon Salon @relation(fields: [salonId], references: [id], onDelete: Cascade)

  @@map("salon_images")
}

// ─── Favorites ───────────────────────────────────────────────────────────────

model FavoriteSalon {
  userId    String
  salonId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  salon Salon @relation(fields: [salonId], references: [id], onDelete: Cascade)

  @@id([userId, salonId])
  @@map("favorite_salons")
}
